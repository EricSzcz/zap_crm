# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Django ─────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── PostgreSQL ─────────────────────────────────────────────────────────────
# When connecting from the HOST (local dev) to the Docker container:
#   DB_HOST=localhost  DB_PORT=5433  (mapped host port)
# Inside Docker Compose, web/worker override DB_HOST=db and DB_PORT=5432 automatically.
DB_NAME=zap_crm
DB_USER=zap_user
DB_PASSWORD=zap_pass
DB_HOST=localhost
DB_PORT=5433

# ── Redis ──────────────────────────────────────────────────────────────────
# When connecting from the HOST (local dev) to the Docker container:
#   REDIS_URL=redis://localhost:6380/0  (mapped host port)
# Inside Docker Compose, web/worker override REDIS_URL=redis://redis:6379/0 automatically.
REDIS_URL=redis://localhost:6380/0

# ── Fernet encryption key ──────────────────────────────────────────────────
# Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# ── Meta WhatsApp Business API ─────────────────────────────────────────────
META_WEBHOOK_APP_SECRET=
